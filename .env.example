# Copy to .env and fill in. .env is gitignored.
# These mirror values from ~/.lean/credentials (written by `lean login`).
# If left blank, scripts/_common.sh falls back to ~/.lean/credentials.

QC_USER_ID=
QC_API_TOKEN=

# Default project for scripts (override per-call with -p <id>)
QC_PROJECT_ID=31715502
